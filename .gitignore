# Python bytecode cache
__pycache__/
*.py[cod]

# Runtime databases — ignore all .db files but keep the db/ directory
# and its README tracked so the directory structure is documented in git.
*.db
!db/
!db/README.md

# macOS metadata
.DS_Store

# Editor / IDE artifacts
.vscode/
.idea/

# Swap files
*.swp
*.swo

# Virtual environment created by install_offline.sh / manual `python3 -m venv .venv`
.venv/

# Offline release bundles built by scripts/build_release_bundle.sh --
# regenerate from source, don't commit the archive itself.
ConfigFoundry-Offline-*.zip
ConfigFoundry-Offline-*.zip.sha256
